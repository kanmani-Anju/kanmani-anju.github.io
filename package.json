{
  "name": "kanmani-anju",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://kanmani-anju.github.io/",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/copy-404.cjs",
    "build:gh": "vite build --base=/",
    "preview": "vite preview",
    "preview:gh": "vite preview --base=/",
    "deploy": "npm run build:gh && gh-pages -d dist",
    "git:diagnose": "powershell -ExecutionPolicy Bypass -File ./scripts/diagnose-push.ps1",
    "lint": "eslint .",
    "ci": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.11"
  }
